{
    "name": "jackwander/laravel-module-maker",
    "version": "2.5.1",
    "description": "A zero-config custom module creator for Laravel 11 projects.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jerwin",
            "email": "me@jackwander.pro"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Jackwander\\ModuleMaker\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jackwander\\ModuleMaker\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jackwander\\ModuleMaker\\ModuleServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
